{
  "name": "partizan-api",
  "version": "1.0.0",
  "description": "Node.js TypeScript backend proxy for Euroleague APIs",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "node --env-file=.env --import tsx/esm --watch src/index.ts",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "cloudinary": "^2.9.0",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "fast-xml-parser": "^4.4.1",
    "multer": "^2.1.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^2.1.0",
    "@types/node": "^20.14.0",
    "tsx": "^4.15.7",
    "typescript": "^5.5.2"
  }
}
